wizard_discord_creds() {
    info "Discord bot credentials"
    cat <<'EOF'

Steps (one-time, ~5 minutes):
  1. https://discord.com/developers/applications → New Application → Bot
  2. Copy the bot token
  3. OAuth2 → URL Generator → scopes: bot
     permissions: View Channel, Send Messages, Create Public Threads,
                  Send Messages in Threads, Read Message History, Add Reactions
  4. Open the generated URL → invite the bot to your server
  5. In Discord: Settings → Advanced → Developer Mode ON
  6. CREATE A DEDICATED CHANNEL for this project (e.g. #c3r-myproject)
     and ONLY grant the bot access to that channel
  7. Right-click the channel → Copy Channel ID
  8. Right-click your own name → Copy User ID

EOF
    load_config
    local tok cid uid
    tok=$(ask "Discord bot token [${DISCORD_BOT_TOKEN:+keep existing}]: " "${DISCORD_BOT_TOKEN:-}")
    cid=$(ask "Project channel ID [${DISCORD_CHANNEL_ID:-}]: " "${DISCORD_CHANNEL_ID:-}")
    uid=$(ask "Your Discord user ID [${DISCORD_USER_ID:-}]: " "${DISCORD_USER_ID:-}")
    [ -n "$tok" ] && [ -n "$cid" ] && [ -n "$uid" ] || die "all three values required"
    export DISCORD_BOT_TOKEN="$tok" DISCORD_CHANNEL_ID="$cid" DISCORD_USER_ID="$uid"
    save_config
}

wizard_smoke() {
    info "Discord round-trip smoke test (free-text)"
    local reply
    reply=$("$C3R_BIN/ask_human.py" "c3r smoke test — reply with any text" --timeout-min 5) || die "smoke test failed"
    [ "$reply" = "TIMEOUT_NO_HUMAN_RESPONSE" ] && die "smoke test timed out — is the bot in the right channel?"
    ok "free-text reply: $reply"
    info "Discord MCQ smoke test"
    local choice
    choice=$("$C3R_BIN/ask_human.py" "MCQ smoke test — tap one" --choices "left" "middle" "right" --timeout-min 5) || die "MCQ test failed"
    [ "$choice" = "TIMEOUT_NO_HUMAN_RESPONSE" ] && die "MCQ test timed out"
    ok "MCQ reply: $choice"
}

# render a PROMPT.md by substituting {{PLACEHOLDERS}} from template
render_prompt() {
    local template="$1" out="$2"
    local name="$3" role="$4" focus="$5" siblings="$6" own="$7" notown="$8" ping_budget="$9"
    # Use python for safe substitution (bash sed gets messy with special chars in focus text)
    python3 - "$template" "$out" "$name" "$role" "$focus" "$siblings" "$own" "$notown" "$ping_budget" <<'PY'
import sys
_, tpl, out, name, role, focus, siblings, own, notown, budget = sys.argv
with open(tpl) as f: s = f.read()
sib_up = siblings.upper().replace(",", "_").replace(" ", "")
reasons = "Three consecutive runs inconclusive\n- Fundamental reward/architecture redesign\n- Hardware constraint you cannot resolve"
s = (s.replace("{{AGENT_NAME}}", name)
      .replace("{{AGENT_ROLE}}", role)
      .replace("{{FOCUS}}", focus)
      .replace("{{SIBLINGS}}", siblings or "(none)")
      .replace("{{SIBLING_UPPER}}", sib_up or "OTHERS")
      .replace("{{SCOPE_OWN}}", own)
      .replace("{{SCOPE_NOT}}", notown)
      .replace("{{PING_BUDGET}}", budget)
      .replace("{{PING_REASONS}}", reasons))
with open(out, "w") as f: f.write(s)
PY
}

write_agent_conf() {
    local wt="$1" name="$2" role="$3" model="$4" thread="${5:-}"
    cat > "$wt/.c3r/agent.conf" <<EOF
AGENT_NAME="$name"
AGENT_ROLE="$role"
AGENT_MODEL="$model"
ITERATION_COOLDOWN_SEC=20
MAX_CONSECUTIVE_FAILURES=5
CONTEXT_ALERT_THRESHOLDS="25 50 75 100"
C3R_AGENT_THREAD_ID="$thread"
EOF
}

cmd_init() {
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    [ -d "$target/.git" ] || die "not a git repo: $target"
    info "target: $target"

    local project_name
    project_name=$(ask "Project name (alnum, for tmux session + board title) [$(basename "$target")]: " "$(basename "$target")")

    local n_agents
    n_agents=$(ask "Number of agents to create [2]: " "2")
    [[ "$n_agents" =~ ^[1-9][0-9]*$ ]] || die "invalid agent count"

    declare -a AG_NAMES AG_ROLES AG_MODELS AG_FOCI
    for i in $(seq 1 "$n_agents"); do
        echo
        info "Agent $i of $n_agents"
        local name role model focus
        while :; do
            name=$(ask "  name [agent$i] (letters/digits/dash/underscore only): " "agent$i")
            if [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]]; then break; fi
            warn "invalid — spaces and special chars not allowed in a git branch name"
        done
        echo "  Role templates: generic | literature | coding | writing | custom"
        role=$(ask "  role [generic]: " "generic")
        echo "  Models: sonnet (default) | opus | haiku"
        local m_short; m_short=$(ask "  model [sonnet]: " "sonnet")
        case "$m_short" in
            sonnet) model="claude-sonnet-4-6" ;;
            opus)   model="claude-opus-4-6" ;;
            haiku)  model="claude-haiku-4-5-20251001" ;;
            claude-*) model="$m_short" ;;
            *) die "unknown model: $m_short" ;;
        esac
        focus=$(ask "  one-sentence focus: " "")
        [ -n "$focus" ] || die "focus is required"
        AG_NAMES+=("$name"); AG_ROLES+=("$role"); AG_MODELS+=("$model"); AG_FOCI+=("$focus")
    done

    echo
    info "GPU lock mode"
    cat <<'EOF'
  serial  (default) — only one agent's GPU workload runs at a time (flock-based).
                      Safe for single-GPU boxes. Agents block on each other.
  none              — no GPU lock. Use only if agents don't touch the GPU or
                      you have per-agent GPUs allocated manually.
EOF
    local gpu_mode; gpu_mode=$(ask "GPU lock [serial]: " "serial")

    echo
    info "Agent hierarchy cap"
    cat <<'EOF'
  Top-level agents can spawn sub-agents (children) for bounded tasks. The cap
  below is the TOTAL number of agents that can exist at once (top-level +
  children combined). When hit, further `c3r spawn` calls fail with an error
  so the caller can decide to wait or kill another agent.
EOF
    local max_agents; max_agents=$(ask "Max parallel agents cap [4]: " "4")
    [[ "$max_agents" =~ ^[1-9][0-9]*$ ]] || die "max_agents must be a positive integer"

    # Discord creds
    echo
    load_config
    if [ -n "${DISCORD_BOT_TOKEN:-}" ] && [ -n "${DISCORD_CHANNEL_ID:-}" ] && [ -n "${DISCORD_USER_ID:-}" ]; then
        ok "Discord config already saved"
        local reuse; reuse=$(ask "Reuse existing config? [Y/n]: " "Y")
        [[ "$reuse" =~ ^[Nn] ]] && wizard_discord_creds
    else
        wizard_discord_creds
    fi

    local do_smoke; do_smoke=$(ask "Run Discord smoke test? [Y/n]: " "Y")
    [[ ! "$do_smoke" =~ ^[Nn] ]] && wizard_smoke

    # Worktrees
    info "creating git worktrees..."
    "$C3R_DIR/scripts/setup_worktrees.sh" "$target" "${AG_NAMES[@]}"

    # state.json — pass names/roles/models/foci via env (foci may contain spaces)
    mkdir -p "$target/.c3r"
    local state="$target/.c3r/state.json"
    _C3R_NAMES="$(printf '%s\x1f' "${AG_NAMES[@]}")" \
    _C3R_ROLES="$(printf '%s\x1f' "${AG_ROLES[@]}")" \
    _C3R_MODELS="$(printf '%s\x1f' "${AG_MODELS[@]}")" \
    _C3R_FOCI="$(printf '%s\x1f' "${AG_FOCI[@]}")" \
    python3 - > "$state" <<PY
import json, os
def _split(k): return os.environ[k].rstrip("\x1f").split("\x1f")
names = _split("_C3R_NAMES")
roles = _split("_C3R_ROLES")
models = _split("_C3R_MODELS")
foci = _split("_C3R_FOCI")
agents = []
parent = "$(dirname "$target")"; repo_name = "$(basename "$target")"
for n, r, m, f in zip(names, roles, models, foci):
    agents.append({
        "name": n, "role": r, "model": m, "focus": f,
        "parent": None,
        "branch": f"agent/{n}",
        "worktree": f"{parent}/{repo_name}-{n}",
        "thread_id": None, "status": "idle",
        "last_iter": 0, "last_iter_ts": None,
        "last_context_pct": 0, "fail_streak": 0,
    })
state = {
    "project": "$project_name",
    "channel_id": "$DISCORD_CHANNEL_ID",
    "board_message_id": None,
    "gpu_lock": "$gpu_mode",
    "max_agents": $max_agents,
    "paused": False,
    "agents": agents,
}
print(json.dumps(state, indent=2))
PY
    ok "wrote $state"

    # Seed per-worktree .c3r/
    local parent; parent="$(dirname "$target")"
    local repo_name; repo_name="$(basename "$target")"
    for i in "${!AG_NAMES[@]}"; do
        local name="${AG_NAMES[$i]}" role="${AG_ROLES[$i]}" model="${AG_MODELS[$i]}" focus="${AG_FOCI[$i]}"
        local wt="$parent/${repo_name}-${name}"
        mkdir -p "$wt/.c3r"
        # siblings list
        local siblings=""
        for j in "${!AG_NAMES[@]}"; do [ "$i" != "$j" ] && siblings+="${AG_NAMES[$j]},"; done
        siblings="${siblings%,}"
        # role template
        local tpl="$C3R_DIR/templates/PROMPT_${role}.md"
        [ -f "$tpl" ] || tpl="$C3R_DIR/templates/PROMPT_generic.md"
        render_prompt "$tpl" "$wt/.c3r/PROMPT.md" "$name" "$role" "$focus" "$siblings" "(agent-defined)" "(sibling-owned)" "1"
        [ -f "$wt/.c3r/fix_plan.md" ]     || cp "$C3R_DIR/templates/fix_plan.md"     "$wt/.c3r/fix_plan.md"
        [ -f "$wt/.c3r/RESEARCH_LOG.md" ] || cp "$C3R_DIR/templates/RESEARCH_LOG.md" "$wt/.c3r/RESEARCH_LOG.md"
        [ -f "$wt/.c3r/INBOX.md" ]        || cp "$C3R_DIR/templates/INBOX.md"        "$wt/.c3r/INBOX.md"
        write_agent_conf "$wt" "$name" "$role" "$model"
        ok "seeded $wt/.c3r/ ($role)"
    done

    # Symlink scripts/c3r → $C3R_BIN
    local link="$target/scripts/c3r"
    mkdir -p "$target/scripts"
    [ -e "$link" ] || { ln -s "$C3R_BIN" "$link"; ok "symlinked $link → $C3R_BIN"; }

    # Post the status board & create threads
    info "creating Discord status board + agent threads..."
    "$C3R_BIN/status_board.py" init --state "$state" >/dev/null
    ok "status board posted"

    # Copy thread IDs from state back into each agent's agent.conf
    python3 - "$state" "$parent" "$repo_name" <<'PY'
import json, sys, pathlib
state = json.load(open(sys.argv[1])); parent, repo = sys.argv[2], sys.argv[3]
for a in state["agents"]:
    conf = pathlib.Path(a["worktree"]) / ".c3r" / "agent.conf"
    if not conf.exists(): continue
    lines = conf.read_text().splitlines()
    out = []
    for line in lines:
        if line.startswith("C3R_AGENT_THREAD_ID="):
            out.append(f'C3R_AGENT_THREAD_ID="{a.get("thread_id","")}"')
        else:
            out.append(line)
    conf.write_text("\n".join(out) + "\n")
PY
    ok "wrote thread IDs into agent.conf files"

    # Seed fix_plan interactively
    echo
    info "Seed each agent's fix_plan.md with 3-5 concrete starting tasks?"
    local do_seed; do_seed=$(ask "Seed now? [Y/n]: " "Y")
    if [[ ! "$do_seed" =~ ^[Nn] ]]; then
        for i in "${!AG_NAMES[@]}"; do
            local name="${AG_NAMES[$i]}"
            local wt="$parent/${repo_name}-${name}"
            echo
            info "fix_plan.md for $name (one task per line; empty line to finish):"
            local -a tasks=()
            local line
            while IFS= read -rp "  > " line && [ -n "$line" ]; do tasks+=("$line"); done
            if [ "${#tasks[@]}" -gt 0 ]; then
                {
                    echo "# fix_plan.md — experiment queue for $name"
                    echo
                    for t in "${tasks[@]}"; do echo "- [ ] $t"; done
                } > "$wt/.c3r/fix_plan.md"
                ok "seeded ${#tasks[@]} tasks into $wt/.c3r/fix_plan.md"
            fi
        done
    fi

    cat <<EOF

${GREEN}${BOLD}c3r init complete.${RESET}

Launch the agents:
  c3r launch $target

Attach:
  tmux attach -t c3r-$project_name

Pause anytime from your phone:  !c3r pause   (in your Discord channel)
Resume:                         !c3r resume
Talk to an agent:               reply in its Discord thread
EOF
}

