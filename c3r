cmd_ping() {
    load_config
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    if [ -f "$target/.c3r/state.json" ]; then shift; else target="$PWD"; fi
    local state; state="$(require_state "$target")"
    local agent="${1:?usage: c3r ping [path] AGENT_NAME MESSAGE}"; shift
    local msg="$*"
    [ -n "$msg" ] || die "message required"
    python3 - "$state" "$agent" "$msg" <<'PY'
import json, sys, pathlib, os
from datetime import datetime, timezone
state_path, agent, msg = sys.argv[1:4]
state = json.load(open(state_path))
a = next((x for x in state["agents"] if x["name"] == agent), None)
if not a: print(f"no such agent: {agent}", file=sys.stderr); raise SystemExit(1)
inbox = pathlib.Path(a["worktree"]) / ".c3r/INBOX.md"
inbox.parent.mkdir(parents=True, exist_ok=True)
if not inbox.exists() or "<!-- empty -->" in inbox.read_text():
    inbox.write_text("# INBOX\n\n")
ts = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")
with inbox.open("a") as f:
    f.write(f"\n---\n**you (cli)** · {ts}\n\n{msg}\n")
print(f"delivered to {agent}")
# Also post in the agent's Discord thread for symmetry
if a.get("thread_id"):
    import subprocess
    subprocess.run([f"{os.path.dirname(os.path.realpath(__file__))}/notify.py",
                    "--thread", a["thread_id"],
                    f"📨 **you (cli)**: {msg}"], check=False)
PY
    ok "delivered"
}

