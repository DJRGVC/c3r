cmd_update() {
    info "git pull in $C3R_DIR"
    git -C "$C3R_DIR" pull --ff-only
}

cmd_upgrade() {
    load_config
    local target; target="$(resolve_target "${1:-}")"
    local state; state="$(require_state "$target")"

    info "upgrading $target"
    info "  1/5: pulling latest c3r"
    git -C "$C3R_DIR" pull --ff-only --quiet || warn "  c3r pull failed (continuing)"

    local session; session="c3r-$(python3 -c "import json;print(json.load(open('$state'))['project'])")"

    # Cooperative pause first so any in-flight training run can checkpoint
    # and finish cleanly before we restart the loop
    info "  2/5: cooperative pause (waits for in-flight iterations to finish)"
    if tmux has-session -t "$session" 2>/dev/null; then
        # Touch the pause flag in each worktree
        python3 - "$state" <<'PY'
import json, sys, pathlib
s = json.load(open(sys.argv[1]))
for a in s["agents"]:
    if a.get("status") != "stopped":
        pathlib.Path(a["worktree"]).joinpath(".c3r/PAUSED").touch()
PY
        ok "  PAUSE flag set; waiting up to 90s for agents to enter paused state"

        # Poll status.json for up to 90 seconds, looking for all active
        # agents to be in 'paused' or 'idle' state (i.e. not 'running')
        local waited=0
        while [ "$waited" -lt 90 ]; do
            local still_running
            still_running=$(python3 - "$state" <<'PY'
import json, sys
s = json.load(open(sys.argv[1]))
running = [a["name"] for a in s["agents"]
           if a.get("status") == "running" and a.get("status") != "stopped"]
print(len(running), *running)
PY
)
            local n=$(echo "$still_running" | awk '{print $1}')
            if [ "$n" = "0" ]; then
                ok "  all agents idle"
                break
            fi
            printf "\r  waiting for %s active agents to finish their iteration... (%ds)" "$n" "$waited"
            sleep 5
            waited=$((waited + 5))
        done
        echo
        if [ "$waited" -ge 90 ]; then
            warn "  90s timeout reached; some agents may still be mid-iteration. Killing anyway."
        fi

        info "  3/5: stopping tmux session"
        tmux kill-session -t "$session" 2>/dev/null && ok "  killed $session" || true
    else
        info "  2/5: no tmux session running (skipping pause)"
        info "  3/5: nothing to stop"
    fi

    info "  4/5: re-rendering PROMPT.md, agent.conf, .claude/settings.json in each worktree"
    python3 - "$state" "$C3R_DIR" <<'PY'
import json, os, re, sys
from pathlib import Path
state_path, c3r_dir = sys.argv[1:]
state = json.load(open(state_path))
template = (Path(c3r_dir) / "templates" / "PROMPT_generic.md").read_text()
sandbox = Path(c3r_dir) / "templates" / "claude_settings.json"

# Build siblings list once
all_names = [a["name"] for a in state["agents"] if a.get("status") != "stopped"]

upgraded = 0
for a in state["agents"]:
    wt = Path(a["worktree"])
    if not (wt / ".c3r").exists():
        print(f"  skip {a['name']}: no .c3r dir")
        continue
    name = a["name"]; role = a.get("role", "generic"); focus = a.get("focus", "")
    siblings = ",".join(n for n in all_names if n != name) or "(none)"
    sib_up = siblings.upper().replace(",", "_").replace(" ", "") or "OTHERS"
    reasons = "Three consecutive runs inconclusive\n- Fundamental reward/architecture redesign\n- Hardware constraint you cannot resolve"
    rendered = (template
        .replace("{{AGENT_NAME}}", name)
        .replace("{{AGENT_ROLE}}", role)
        .replace("{{FOCUS}}", focus)
        .replace("{{SIBLINGS}}", siblings)
        .replace("{{SIBLING_UPPER}}", sib_up)
        .replace("{{SCOPE_OWN}}", "(agent-defined)")
        .replace("{{SCOPE_NOT}}", "(sibling-owned)")
        .replace("{{PING_BUDGET}}", "1")
        .replace("{{PING_REASONS}}", reasons))
    (wt / ".c3r/PROMPT.md").write_text(rendered)

    # agent.conf: add ITERATION_TIMEOUT_SEC if missing
    conf_path = wt / ".c3r/agent.conf"
    if conf_path.exists():
        conf = conf_path.read_text()
        if "ITERATION_TIMEOUT_SEC" not in conf:
            with conf_path.open("a") as f:
                f.write('\n# Per-iteration wall-clock cap (added by c3r upgrade)\nITERATION_TIMEOUT_SEC=5400\n')

    # .claude/settings.json: seed sandbox hook if missing
    claude_dir = wt / ".claude"
    claude_dir.mkdir(parents=True, exist_ok=True)
    cs = claude_dir / "settings.json"
    if not cs.exists() or '"sandbox_check.py"' not in cs.read_text():
        cs.write_text(sandbox.read_text())

    upgraded += 1
    print(f"  upgraded {name}: PROMPT + agent.conf + sandbox hook")

print(f"\nupgraded {upgraded} worktree(s)")
PY

    # Clear the pause flags we set in step 2 so agents come back online
    python3 - "$state" <<'PY'
import json, sys, pathlib
s = json.load(open(sys.argv[1]))
for a in s["agents"]:
    try: pathlib.Path(a["worktree"]).joinpath(".c3r/PAUSED").unlink()
    except FileNotFoundError: pass
s["paused"] = False
json.dump(s, open(sys.argv[1], "w"), indent=2)
PY

    info "  5/5: relaunching"
    cmd_launch "$target"

    ok "upgrade complete for $target"
    info "  → c3r watch $target  (verify the new dashboard)"
    info "  → !c3r status        (re-pin board in Discord, requires Manage Messages)"
}

cmd_listen() {
    load_config
    local target; target="$(resolve_target "${1:-}")"
    local state; state="$(require_state "$target")"
    export C3R_STATE="$state"
    exec "$C3R_BIN/listen.py"
}

# ------------------------------------------------------------------
# dispatch
# ------------------------------------------------------------------
load_config
cmd="${1:-help}"; shift || true
case "$cmd" in
    init|setup) cmd_init     "$@" ;;
    launch)    cmd_launch    "$@" ;;
    attach|a)  cmd_attach    "$@" ;;
    watch|w)   cmd_watch     "$@" ;;
    stop)      cmd_stop      "$@" ;;
    pause)     cmd_pause     "$@" ;;
    resume)    cmd_resume    "$@" ;;
    status)    cmd_status    "$@" ;;
    logs)      cmd_logs      "$@" ;;
    ask)       cmd_ask       "$@" ;;
    ping)      cmd_ping      "$@" ;;
    add-agent) cmd_add_agent "$@" ;;
    spawn)     cmd_spawn     "$@" ;;
    kill)      cmd_kill      "$@" ;;
    reset)     cmd_reset     "$@" ;;
    update)    cmd_update    "$@" ;;
    upgrade)   cmd_upgrade   "$@" ;;
    version|--version|-v) cmd_version ;;
    uninstall) cmd_uninstall "$@" ;;
    doctor)    cmd_doctor    "$@" ;;
    config)    cmd_config    "$@" ;;
    install)   cmd_install   "$@" ;;
    board)     cmd_board     "$@" ;;
    listen)    cmd_listen    "$@" ;;
    usage-auth) cmd_usage_auth "$@" ;;
    help|-h|--help) cmd_help "$@" ;;
    *) cmd_help; die "unknown command: $cmd" ;;
esac
