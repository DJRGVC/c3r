    [ -f "$tpl" ] || tpl="$C3R_DIR/templates/PROMPT_generic.md"
    local siblings="(see state.json)"
    render_prompt "$tpl" "$wt/.c3r/PROMPT.md" "$name" "$role" "$focus" "$siblings" "(agent-defined)" "(sibling-owned)" "1"
    cp "$C3R_DIR/templates/fix_plan.md"     "$wt/.c3r/fix_plan.md"
    cp "$C3R_DIR/templates/RESEARCH_LOG.md" "$wt/.c3r/RESEARCH_LOG.md"
    cp "$C3R_DIR/templates/INBOX.md"        "$wt/.c3r/INBOX.md"
    printf '# INBOX ARCHIVE\n' > "$wt/.c3r/INBOX_ARCHIVE.md"
    write_agent_conf "$wt" "$name" "$role" "$model"
    # Append the iteration budget — agent_loop.sh self-kills when last_iter >= MAX_ITERATIONS
    if [ "$max_iters" -gt 0 ] 2>/dev/null; then
        echo "MAX_ITERATIONS=$max_iters" >> "$wt/.c3r/agent.conf"
    fi
    # Sandbox hook
    mkdir -p "$wt/.claude"
    cp "$C3R_DIR/templates/claude_settings.json" "$wt/.claude/settings.json"

    # Create Discord thread
    python3 - "$state" "$name" "$role" "$model" "$focus" "$wt" "$parent" <<'PY'
import json, os, sys, urllib.request
sp, name, role, model, focus, wt, parent = sys.argv[1:]
parent = parent or None
s = json.load(open(sp))
token = os.environ["DISCORD_BOT_TOKEN"]; channel = s["channel_id"]
# Descriptive thread title: "name · focus" (Discord cap 100 chars)
# Root agents: "name · focus"; Children: "↳ name · focus" to visually mark subtasks.
prefix = "↳ " if parent else ""
title = f"{prefix}{name} · {focus}"[:100]
req = urllib.request.Request(f"https://discord.com/api/v10/channels/{channel}/threads",
    data=json.dumps({"name": title, "type": 11, "auto_archive_duration": 10080}).encode(),
    method="POST")
req.add_header("Authorization", f"Bot {token}")
req.add_header("Content-Type", "application/json")
req.add_header("User-Agent", "c3r-spawn (0.1)")
with urllib.request.urlopen(req, timeout=30) as r:
    thread = json.loads(r.read())
# Welcome message
parent_line = f" · spawned by **{parent}**" if parent else ""
wreq = urllib.request.Request(f"https://discord.com/api/v10/channels/{thread['id']}/messages",
    data=json.dumps({"content": f"**{name}** — {role} · `{model}`{parent_line}\nFocus: {focus}\n\nReply here to send the agent an INBOX message."}).encode(),
    method="POST")
wreq.add_header("Authorization", f"Bot {token}")
wreq.add_header("Content-Type", "application/json")
wreq.add_header("User-Agent", "c3r-spawn (0.1)")
urllib.request.urlopen(wreq, timeout=30).read()
# Append to state
s["agents"].append({
    "name": name, "role": role, "model": model, "focus": focus,
    "parent": parent,
    "branch": f"agent/{name}", "worktree": wt,
    "thread_id": thread["id"], "status": "idle",
    "last_iter": 0, "last_iter_ts": None,
    "last_context_pct": 0, "fail_streak": 0,
})
json.dump(s, open(sp, "w"), indent=2)
# Write thread id back to agent.conf
conf_path = os.path.join(wt, ".c3r/agent.conf")
lines = open(conf_path).read().splitlines()
out = []
for line in lines:
    if line.startswith("C3R_AGENT_THREAD_ID="):
        out.append(f'C3R_AGENT_THREAD_ID="{thread["id"]}"')
    else:
        out.append(line)
open(conf_path, "w").write("\n".join(out) + "\n")
print(thread["id"])
PY

    # If tmux session is live, add a window for the new agent
    local session; session="c3r-$(python3 -c "import json;print(json.load(open('$state'))['project'])")"
    if tmux has-session -t "$session" 2>/dev/null; then
        local thread_id; thread_id="$(python3 -c "import json;s=json.load(open('$state'));print([a['thread_id'] for a in s['agents'] if a['name']=='$name'][0])")"
        # SECURITY: source config.env so credentials never appear on argv
        local env_cmd="cd '$wt' && \
set -a; . '$CONFIG_FILE'; set +a; \
export C3R_DIR='$C3R_DIR' C3R_BIN='$C3R_BIN' C3R_STATE='$state' \
C3R_AGENT_NAME='$name' C3R_WORKTREE='$wt' \
C3R_AGENT_THREAD_ID='$thread_id' && \
'$C3R_BIN/agent_loop.sh'"
        tmux new-window -t "$session" -n "$name" "bash -lc \"$env_cmd\""
        ok "spawned $name → live in tmux session $session"
    else
        ok "spawned $name (tmux session not running — start with 'c3r launch')"
    fi

    "$C3R_BIN/status_board.py" update --state "$state" || true
}

cmd_add_agent() { cmd_spawn "$@"; }

cmd_kill() {
    load_config
    local target; target="$(resolve_target "${1:-}")"
    if [ -f "$target/.c3r/state.json" ]; then shift; else target="$PWD"; fi
    local state; state="$(require_state "$target")"
    local name="${1:?usage: c3r kill AGENT_NAME}"

    # Compute the set of agents to kill: target + all descendants
    # Enforce permission: if called from an agent (C3R_AGENT_NAME set), the
    # target must be self or a descendant of self.
    local caller="${C3R_AGENT_NAME:-}"
    local to_kill; to_kill=$(python3 - "$state" "$name" "$caller" <<'PY'
import json, sys
sp, target, caller = sys.argv[1:]
s = json.load(open(sp))
by_name = {a["name"]: a for a in s["agents"]}
if target not in by_name:
    print(f"ERR: no such agent: {target}", file=sys.stderr); sys.exit(2)
# Compute descendants
def descendants(n):
    out = [n]
    for a in s["agents"]:
        if a.get("parent") == n:
            out += descendants(a["name"])
    return out
kill_set = descendants(target)
# Permission check for agent callers
if caller:
    # caller may only kill self or a descendant of self
    caller_desc = set(descendants(caller))
    if target not in caller_desc and target != caller:
        print(f"ERR: agent '{caller}' cannot kill '{target}' (not in its subtree)", file=sys.stderr); sys.exit(3)
print(" ".join(kill_set))
PY
)
    local rc=$?; [ "$rc" -ne 0 ] && return $rc
    [ -z "$to_kill" ] && die "nothing to kill"

    local session; session="c3r-$(python3 -c "import json;print(json.load(open('$state'))['project'])")"
    for agent in $to_kill; do
        # Kill tmux window if session exists
        if tmux has-session -t "$session" 2>/dev/null; then
            tmux kill-window -t "$session:$agent" 2>/dev/null || true
        fi
        # Mark stopped + handle thread:
        #   - sub-agent (has parent): DELETE the thread — ephemeral, keeps channel clean
        #   - top-level agent: post farewell, keep thread for history
        python3 - "$state" "$agent" <<'PY'
import json, os, sys, subprocess, urllib.error, urllib.request
sp, name = sys.argv[1:]
s = json.load(open(sp))
agent = next((a for a in s["agents"] if a["name"] == name), None)
if not agent: sys.exit(0)
is_sub = bool(agent.get("parent"))
agent["status"] = "stopped"
thread_id = agent.get("thread_id")
if thread_id:
    token = os.environ["DISCORD_BOT_TOKEN"]
    if is_sub:
        # Delete the sub-agent's thread entirely
        req = urllib.request.Request(
            f"https://discord.com/api/v10/channels/{thread_id}",
            method="DELETE")
        req.add_header("Authorization", f"Bot {token}")
        req.add_header("User-Agent", "c3r-kill (0.1)")
        try:
            urllib.request.urlopen(req, timeout=15).read()
            agent["thread_id"] = None
            print(f"[kill] deleted sub-agent thread for {name}", file=sys.stderr)
        except urllib.error.HTTPError as e:
            print(f"[kill] could not delete thread for {name}: HTTP {e.code} {e.read().decode(errors='replace')}", file=sys.stderr)
            print(f"[kill]   (bot needs 'Manage Threads' permission to delete; falling back to farewell post)", file=sys.stderr)
            subprocess.run([f"{os.path.dirname(os.path.realpath(__file__))}/bin/notify.py",
                            "--thread", thread_id,
                            "🛑 Sub-agent stopped (thread deletion failed — grant Manage Threads)."],
                           check=False, cwd=os.path.dirname(os.path.realpath(__file__)))
    else:
        # Top-level agent: keep thread, post farewell
        subprocess.run([f"{os.path.dirname(os.path.realpath(__file__))}/bin/notify.py",
                        "--thread", thread_id,
                        "🛑 Agent stopped. Worktree and history preserved."],
                       check=False, cwd=os.path.dirname(os.path.realpath(__file__)))
json.dump(s, open(sp, "w"), indent=2)
PY
        ok "killed $agent"
    done
    "$C3R_BIN/status_board.py" update --state "$state" || true
}

cmd_reset() {
    local target; target="$(resolve_target "${1:-}")"
    if [ -f "$target/.c3r/state.json" ]; then shift; else target="$PWD"; fi
    local name="${1:?usage: c3r reset [path] AGENT_NAME}"
    local state; state="$(require_state "$target")"
    local wt; wt="$(python3 -c "import json;s=json.load(open('$state'));print(next(a['worktree'] for a in s['agents'] if a['name']=='$name'))")"
    warn "this will delete: $wt and branch agent/$name"
    local confirm; confirm=$(ask "Proceed? [y/N]: " "N")
    [[ "$confirm" =~ ^[Yy] ]] || { info "aborted"; return 0; }
    cd "$target"
    git worktree remove --force "$wt" || true
    git branch -D "agent/$name" || true
    python3 - "$state" "$name" <<'PY'
import json, sys
state_path, name = sys.argv[1:3]
s = json.load(open(state_path))
s["agents"] = [a for a in s["agents"] if a["name"] != name]
json.dump(s, open(state_path, "w"), indent=2)
PY
    "$C3R_BIN/status_board.py" update --state "$state" || true
    ok "removed agent $name"
}

