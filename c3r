    r'\[([^\]]+)\]\s*([^\n→]+?)\s*→\s*(\w+)\s*\n'
    r'MSG:\s*(.+?)(?=\n(?:RESP:|---|\Z))'
    r'(?:\nRESP:\s*(.+?))?(?=\n---|\Z)',
    re.DOTALL,
