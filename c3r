cmd_launch() {
    load_config
    local target; target="$(resolve_target "${1:-}")"
    local state; state="$(require_state "$target")"
    local session; session="c3r-$(python3 -c "import json;print(json.load(open('$state'))['project'])")"

    if tmux has-session -t "$session" 2>/dev/null; then
        ok "session '$session' already running — attach: tmux attach -t $session"
        return 0
    fi

    # Make sure config.env is chmod 600 — if user accidentally chmod'd it
    [ -f "$CONFIG_FILE" ] && chmod 600 "$CONFIG_FILE"

    # Sync each agent's model from agent.conf → state.json so the dashboard
    # reflects runtime config. agent.conf is the source of truth at runtime.
    python3 - "$state" <<'PY'
import json, os, re, sys
path = sys.argv[1]
s = json.load(open(path))
changed = False
for a in s["agents"]:
    conf = os.path.join(a["worktree"], ".c3r/agent.conf")
    if not os.path.exists(conf): continue
    for line in open(conf):
        m = re.match(r'\s*AGENT_MODEL\s*=\s*"([^"]+)"', line)
        if m and a.get("model") != m.group(1):
            a["model"] = m.group(1); changed = True
if changed:
    json.dump(s, open(path, "w"), indent=2)
    print("[c3r] synced models from agent.conf → state.json")
PY

    "$C3R_DIR/scripts/launch_agents.sh" "$target"

    # Add a listener window. SECURITY: source config.env so DISCORD_BOT_TOKEN
    # is not visible in `ps -ef`. The export-on-command-line pattern leaks
    # secrets to any local user with shell access.
    tmux new-window -t "$session" -n "listen" \
        "bash -lc \"set -a; . '$CONFIG_FILE'; set +a; export C3R_STATE='$state' && '$C3R_BIN/listen.py'\""
    ok "session '$session' up (including listener window)"
    info "attach: tmux attach -t $session"
}

cmd_watch() {
    local target; target="$(resolve_target "${1:-}")"
    local state; state="$(require_state "$target")"
    local interval="${2:-1}"
    # Background update check (doesn't block startup)
