wizard_discord_creds() {
    info "Discord bot credentials"
    cat <<'EOF'

Steps (one-time, ~5 minutes):
  1. https://discord.com/developers/applications → New Application → Bot
  2. Copy the bot token
  3. Still on the Bot page → Privileged Gateway Intents →
     enable MESSAGE CONTENT INTENT → Save Changes
     (without this, your thread replies arrive with empty content)
  4. OAuth2 → URL Generator → scopes: bot
     permissions:
       - View Channel
       - Send Messages
       - Create Public Threads
       - Send Messages in Threads
       - Read Message History
       - Add Reactions
       - Manage Threads           (lets c3r delete sub-agent threads on kill)
  5. Open the generated URL → invite the bot to your server
  6. In Discord: Settings → Advanced → Developer Mode ON
  7. CREATE A DEDICATED CHANNEL for this project (e.g. #c3r-myproject)
     and ONLY grant the bot access to that channel
  8. Right-click the channel → Copy Channel ID
  9. Right-click your own name → Copy User ID

EOF
    load_config
    local tok cid uid plan
    # Silent input — token never echoes to terminal, never lands in shell history
    tok=$(ask_secret "Discord bot token (input hidden) [${DISCORD_BOT_TOKEN:+keep existing}]: " "${DISCORD_BOT_TOKEN:-}")
    cid=$(ask "Project channel ID [${DISCORD_CHANNEL_ID:-}]: " "${DISCORD_CHANNEL_ID:-}")
    uid=$(ask "Your Discord user ID [${DISCORD_USER_ID:-}]: " "${DISCORD_USER_ID:-}")
    [ -n "$tok" ] && [ -n "$cid" ] && [ -n "$uid" ] || die "all three values required"
    cat <<'EOF'

Claude plan tier (used to compute % budget in 'c3r watch'):
  pro       — $20/mo
  max-5x    — $100/mo
  max-20x   — $200/mo
  api       — pay-as-you-go
  unknown   — skip budget % display
EOF
    plan=$(ask "Plan [${C3R_PLAN:-max-5x}]: " "${C3R_PLAN:-max-5x}")
    case "$plan" in pro|max-5x|max-20x|api|unknown) ;; *) warn "unknown plan name '$plan'; saving anyway" ;; esac
    export DISCORD_BOT_TOKEN="$tok" DISCORD_CHANNEL_ID="$cid" DISCORD_USER_ID="$uid" C3R_PLAN="$plan"
