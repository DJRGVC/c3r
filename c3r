cookie_header = grab(r"-H ['\"]Cookie: ([^'\"]+)['\"]") or grab(r"--cookie ['\"]([^'\"]+)['\"]")
if not cookie_header:
    print("[usage-auth] no Cookie header found in curl", file=sys.stderr)
    sys.exit(3)

cookies = {}
for kv in cookie_header.split(";"):
    kv = kv.strip()
    if "=" in kv:
        k, v = kv.split("=", 1)
