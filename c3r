# ------------------------------------------------------------------
# install / uninstall / config
# ------------------------------------------------------------------
cmd_version() {
    echo "c3r version $C3R_VERSION ($C3R_GIT_HEAD)"
    echo "  installed at: $C3R_DIR"
    echo "  config:       $CONFIG_FILE"
}

# Periodic update check — caches result so we only hit the network at most
# once every 6 hours. Called by `cmd_watch` and `cmd_doctor` automatically.
# Returns:
#   0 = up to date (or check skipped)
#   1 = update available (writes details to /tmp/c3r_update_available)
check_for_updates() {
    local cache_path="$CONFIG_DIR/last_update_check"
    local now; now=$(date +%s)
    local last=0
    [ -f "$cache_path" ] && last=$(cat "$cache_path" 2>/dev/null || echo 0)
    # Force check via env var for debugging
    if [ -z "${C3R_FORCE_CHECK:-}" ] && [ $((now - last)) -lt 21600 ]; then
        # Check is fresh; emit cached result if it indicates an update
        [ -f /tmp/c3r_update_available ] && return 1
        return 0
    fi
    # Do the check (5s timeout, never blocks for long)
    (
        cd "$C3R_DIR" || exit 0
        timeout 5 git fetch --quiet origin 2>/dev/null || exit 0
        local local_head; local_head=$(git rev-parse HEAD 2>/dev/null)
        local remote_head; remote_head=$(git rev-parse origin/main 2>/dev/null)
        if [ -n "$local_head" ] && [ -n "$remote_head" ] && [ "$local_head" != "$remote_head" ]; then
            # Verify it's a fast-forward (i.e. we'd just pull, not merge)
            if git merge-base --is-ancestor "$local_head" "$remote_head" 2>/dev/null; then
                local commits_behind; commits_behind=$(git rev-list --count "$local_head..$remote_head" 2>/dev/null || echo ?)
                local newest_msg; newest_msg=$(git log "$remote_head" --oneline -1 2>/dev/null || echo "")
                {
                    echo "$commits_behind"
                    echo "$newest_msg"
                } > /tmp/c3r_update_available
                exit 1
            fi
        fi
        rm -f /tmp/c3r_update_available
        exit 0
    )
    local rc=$?
    echo "$now" > "$cache_path"
    return $rc
}

cmd_install() {
    local bin_dir="$HOME/.local/bin"
    mkdir -p "$bin_dir"
    local link="$bin_dir/c3r"
    [ -L "$link" ] || [ -f "$link" ] && { warn "$link exists; overwriting"; rm -f "$link"; }
    ln -s "$C3R_DIR/c3r" "$link"
    ok "symlinked $link → $C3R_DIR/c3r"
    case ":$PATH:" in
        *":$bin_dir:"*) ok "$bin_dir is on PATH" ;;
        *) warn "add to your shell rc: export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
    esac
}

cmd_uninstall() {
    local link="$HOME/.local/bin/c3r"
    if [ -L "$link" ]; then rm -f "$link"; ok "removed $link"
    else warn "$link not present"; fi
}

cmd_config() {
    if [ -f "$CONFIG_FILE" ]; then
        echo "$CONFIG_FILE:"
        sed 's/\(TOKEN="\)[^"]*"/\1***"/; s/\(USER_ID="\)[0-9]\{6,\}"/\1***"/' "$CONFIG_FILE"
    else
        warn "no config yet — run: c3r init"
    fi
}

# ------------------------------------------------------------------
# doctor
# ------------------------------------------------------------------
cmd_doctor() {
    load_config
    local fails=0
    info "c3r version $C3R_VERSION ($C3R_GIT_HEAD)"
    if check_for_updates; then
        :  # up to date
    else
        local n=$(head -1 /tmp/c3r_update_available 2>/dev/null || echo "?")
        local msg=$(sed -n '2p' /tmp/c3r_update_available 2>/dev/null || echo "")
        warn "  update available: $n commits behind origin/main"
        [ -n "$msg" ] && warn "  latest:           $msg"
        warn "  run: c3r update   (then 'c3r upgrade <project>' for each running project)"
    fi
    info "environment"
    for v in DISCORD_BOT_TOKEN DISCORD_CHANNEL_ID DISCORD_USER_ID; do
        if [ -n "${!v:-}" ]; then ok "$v set"; else warn "$v not set"; fails=$((fails+1)); fi
    done
    info "tools"
    for tool in tmux flock python3 git setsid jq; do
        if command -v "$tool" >/dev/null; then ok "$tool → $(command -v "$tool")"
        else warn "$tool missing"; [ "$tool" = jq ] || fails=$((fails+1)); fi
    done
    if command -v claude >/dev/null; then
        ok "claude → $(command -v claude)"
        if claude --version >/dev/null 2>&1; then
            ok "claude CLI responds — likely logged in"
        else
            warn "claude CLI installed but --version failed — try: claude /login"
            fails=$((fails+1))
        fi
    else
        warn "claude CLI missing"; fails=$((fails+1))
    fi

    info "live claude.ai usage tracking"
    if "$C3R_BIN/claude_usage.py" 2>/dev/null | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    if d.get('source') == 'claude.ai_live':
        print(f\"OK plan={d.get('plan','?')} cookies={d.get('cookie_source','?')}\")
        sys.exit(0)
    print(d.get('error','no live data'))
    sys.exit(1)
except Exception as e:
    print(f'parse error: {e}'); sys.exit(1)
" > /tmp/c3r_doctor_usage 2>&1; then
        ok "$(cat /tmp/c3r_doctor_usage)"
    else
        warn "live usage unavailable: $(cat /tmp/c3r_doctor_usage)"
        warn "  fix: visit https://claude.ai/settings/usage in Firefox once, OR run 'c3r usage-auth'"
    fi
    rm -f /tmp/c3r_doctor_usage

    if [ -n "${DISCORD_BOT_TOKEN:-}" ] && [ -n "${DISCORD_CHANNEL_ID:-}" ]; then
        info "Discord bot reachability"
        # When a target path is given, prefer that project's channel_id from
        # state.json over the env var (config.env holds only one channel,
        # which may be from a different project).
        local probe_channel="$DISCORD_CHANNEL_ID"
        if [ "${1:-}" ] && [ -f "$(state_path "$(resolve_target "$1")")" ]; then
            probe_channel=$(python3 -c "import json;print(json.load(open('$(state_path "$(resolve_target "$1")")'))['channel_id'])" 2>/dev/null || echo "$DISCORD_CHANNEL_ID")
        fi
        if PROBE_CHANNEL="$probe_channel" python3 - <<'PY'
import json, os, urllib.request
req = urllib.request.Request(
    f"https://discord.com/api/v10/channels/{os.environ['PROBE_CHANNEL']}",
    headers={
        "Authorization": f"Bot {os.environ['DISCORD_BOT_TOKEN']}",
        # Discord REST requires a User-Agent on all bot requests; without
        # it, the edge returns 403. (This was a doctor-only bug — every
        # other c3r Discord call already sets a UA.)
        "User-Agent": "c3r-doctor (https://github.com/DJRGVC/c3r, 0.3)",
    },
)
try:
    with urllib.request.urlopen(req, timeout=10) as r:
        ch = json.load(r)
    print(f"channel: #{ch.get('name','?')}  type={ch.get('type')}")
except Exception as e:
    print(f"ERROR: {e}"); raise SystemExit(1)
PY
        then ok "bot can read channel $probe_channel"
        else warn "bot cannot read channel $probe_channel — check token & invite perms"; fails=$((fails+1)); fi
    fi

    if [ "${1:-}" ]; then
        local target; target="$(resolve_target "$1")"
        if [ -f "$(state_path "$target")" ]; then
            ok "project state found at $(state_path "$target")"
        else
            warn "no project state at $target"
        fi
    fi

    [ "$fails" -eq 0 ] && ok "doctor: all checks passed" || { warn "doctor: $fails issue(s)"; return 1; }
}

