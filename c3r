existing = next((a for a in s["agents"] if a["name"] == name), None)
if existing and existing.get("status") != "stopped":
    print(f"[spawn] active agent '{name}' already exists", file=sys.stderr); sys.exit(2)
cap = s.get("max_agents", 4)
active = [a for a in s["agents"] if a.get("status") != "stopped"]
if len(active) >= cap:
    print(f"[spawn] max_agents cap reached ({cap} active) — kill or wait for an agent to free a slot", file=sys.stderr); sys.exit(3)
