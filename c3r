#!/usr/bin/env bash
# c3r — Continuous Context Claude Research CLI
# See `c3r help` for an overview or `c3r help <command>` for details.
set -euo pipefail

C3R_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
C3R_BIN="$C3R_DIR/bin"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/c3r"
CONFIG_FILE="$CONFIG_DIR/config.env"

if [ -t 1 ]; then
    BOLD=$'\e[1m'; DIM=$'\e[2m'; GREEN=$'\e[32m'; YELLOW=$'\e[33m'; RED=$'\e[31m'; BLUE=$'\e[34m'; RESET=$'\e[0m'
else
    BOLD=""; DIM=""; GREEN=""; YELLOW=""; RED=""; BLUE=""; RESET=""
fi

info()  { echo "${BOLD}[c3r]${RESET} $*"; }
ok()    { echo "${GREEN}[c3r] ✓${RESET} $*"; }
warn()  { echo "${YELLOW}[c3r] ⚠${RESET} $*" >&2; }
die()   { echo "${RED}[c3r] ✗${RESET} $*" >&2; exit 1; }
ask()   { local prompt="$1" default="${2:-}" var; read -rp "$prompt" var; echo "${var:-$default}"; }

load_config() {
    [ -f "$CONFIG_FILE" ] && { set -a; . "$CONFIG_FILE"; set +a; } || true
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
# c3r config — auto-sourced by the c3r CLI. chmod 600; contains secrets.
export DISCORD_BOT_TOKEN="${DISCORD_BOT_TOKEN:-}"
export DISCORD_CHANNEL_ID="${DISCORD_CHANNEL_ID:-}"
export DISCORD_USER_ID="${DISCORD_USER_ID:-}"
EOF
    chmod 600 "$CONFIG_FILE"
    ok "saved config → $CONFIG_FILE"
}

# Resolve target project: explicit arg > $PWD if it has .c3r/state.json > $PWD if it's a git repo
resolve_target() {
    local arg="${1:-}"
    if [ -n "$arg" ]; then cd "$arg" && git rev-parse --show-toplevel 2>/dev/null || echo "$arg"; return; fi
    if [ -f "$PWD/.c3r/state.json" ]; then echo "$PWD"; return; fi
    git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || echo "$PWD"
}

state_path() { echo "$1/.c3r/state.json"; }

require_state() {
    local s; s="$(state_path "$1")"
    [ -f "$s" ] || die "no project state at $s — run 'c3r init' in that repo first"
    echo "$s"
}

# Small Python helper for JSON state mutations. Usage: py_state <script>
py_state() {
    python3 - "$@"
}

# ------------------------------------------------------------------
# HELP
# ------------------------------------------------------------------
cmd_help() {
    local topic="${1:-}"
    case "$topic" in
    ""|overview)
        cat <<EOF
${BOLD}c3r${RESET} — Continuous Context Claude Research

Run two-or-more Claude Code research agents in parallel on a local project,
with Discord threads as the human-in-the-loop interface and git worktrees
keeping the agents from stepping on each other.

${BOLD}USAGE${RESET}
  c3r <command> [args]
  c3r help <command>      detailed help for one command

${BOLD}SETUP${RESET}
  install                 symlink c3r into ~/.local/bin
  init [path]             interactive project setup wizard
  doctor                  verify env, Discord bot, tools
  config                  show the saved config file

${BOLD}RUNNING${RESET}
  launch [path]           start the tmux session with all agents
  attach [path]           attach to the running tmux session (alias: a)
  watch [path] [sec]      live dashboard (alias: w; default refresh 3s; q quits)
  stop [path]             kill the tmux session (non-destructive)
  pause [path]            pause all agents cooperatively
  resume [path]           resume paused agents
  status [path]           print local status + nudge Discord board

${BOLD}AGENT MANAGEMENT${RESET}
  add-agent [path] ...    add a new agent to an existing project (alias of spawn)
  spawn [path] <n> <role> "<focus>"   dynamically create a new agent
  kill [path] <name>      stop an agent's loop (non-destructive; keeps artifacts)
  reset [path] <name>     delete an agent's worktree + branch (destructive)
  logs [path] [agent]     tail RESEARCH_LOG.md for one or all agents

${BOLD}HUMAN ↔ AGENT${RESET}
  ping [path] <agent> <msg>    send a message to an agent's INBOX
  ask "question" [--choices]   send yourself a Discord question (test harness)
  listen [path]                 start the Discord → INBOX listener (auto-run by launch)
  board [path] (bump|update)    manage the persistent Discord status board

${BOLD}MAINTENANCE${RESET}
  update                  git pull c3r itself (template/tool updates)
  uninstall               remove ~/.local/bin symlink (keeps config)
  help [command]          this message, or detailed help

${BOLD}DISCORD COMMANDS${RESET} (type these in the project channel)
  !c3r help               list commands
  !c3r status             bump the status board
  !c3r pause / resume     same as CLI
  !c3r ping <agent> <msg> same as CLI ping

Config file: $CONFIG_FILE
Templates:   $C3R_DIR/templates/
EOF
        ;;

    init) cat <<'EOF'
c3r init [TARGET_REPO]

Interactive wizard that wires c3r into a target git repo:
  1. Confirms the target is a git repo.
  2. Asks how many agents to create (default 2), and per-agent:
       - name (e.g. policy, perception, literature)
       - role template (generic | literature | coding | writing | custom)
       - one-sentence focus (substituted into the PROMPT.md template)
       - model (claude-sonnet-4-6 [default] | claude-opus-4-6 | claude-haiku-4-5-20251001)
  3. Asks whether the GPU lock should be serial (flock) or none.
  4. Collects Discord bot token, channel ID, user ID (one-time; saved to
     ~/.config/c3r/config.env with chmod 600). If already saved, offers to reuse.
  5. Runs a Discord round-trip smoke test (free-text + MCQ poll).
  6. Creates git worktrees: <parent>/<repo>-<agent> on branch agent/<name>.
  7. Seeds each worktree's .c3r/ with PROMPT.md, fix_plan.md, RESEARCH_LOG.md,
     INBOX.md, agent.conf.
  8. Writes the project state file at <target>/.c3r/state.json.
  9. Posts the persistent status board in your Discord channel and creates
     one thread per agent. Writes thread IDs back into state.json.
 10. Symlinks $C3R_DIR/bin into <target>/scripts/c3r so agents can call tools
     at ./scripts/c3r/ask_human.py etc.

Before running: create a dedicated Discord channel for this project (e.g.
#c3r-yourproject) and grant the bot permissions ONLY on that channel:
  View Channel, Send Messages, Create Public Threads,
  Send Messages in Threads, Read Message History, Add Reactions.

The wizard does NOT launch agents — run `c3r launch` after init to start them.
EOF
        ;;
    launch) cat <<'EOF'
c3r launch [TARGET_REPO]

Starts the tmux session for this project. Reads .c3r/state.json to know how
many agents to start and where their worktrees live. One tmux window per
agent runs bin/agent_loop.sh; a final window tails every agent's
RESEARCH_LOG.md; an additional window runs bin/listen.py so Discord-thread
replies land in the right agent's INBOX.md.

Session name is "c3r-<project>". Attach with:
  tmux attach -t c3r-<project>

If the session already exists, this is a no-op. Use `c3r stop` to kill it.

This command depends on DISCORD_* env vars (auto-sourced from the config).
EOF
        ;;
    stop) cat <<'EOF'
c3r stop [TARGET_REPO]

Kills the tmux session for this project. Non-destructive:
  - worktrees are left intact
  - no branches or commits are touched
  - state.json is left intact
  - Discord status board and threads remain in place

A tmux kill interrupts any in-flight claude -p call cleanly and terminates
any GPU workload that agents had launched. If you want to pause without
interrupting an in-flight training run, use `c3r pause` instead.
EOF
        ;;
    pause) cat <<'EOF'
c3r pause [TARGET_REPO]

Pauses all agents cooperatively: writes a PAUSED flag in each worktree's
.c3r/ dir. Agents check this flag between iterations and spin-sleep rather
than starting a new iteration. Any in-flight iteration (including a running
training job) is allowed to finish first — nothing is killed.

Also updates state.json ("paused": true) and redraws the status board.

Resume with `c3r resume`.
EOF
        ;;
    resume) cat <<'EOF'
c3r resume [TARGET_REPO]

Removes the PAUSED flag from all agent worktrees and flips state.json back
to paused: false. Agents that are currently spin-sleeping will pick up the
next iteration within ~15 seconds.
EOF
        ;;
    status) cat <<'EOF'
c3r status [TARGET_REPO]

Prints a local-side summary:
  - tmux session up/down
  - each agent's branch, last iter, last context %, pause state
  - GPU lock holder (if any)
  - last 3 entries of each agent's RESEARCH_LOG.md

Also forces a re-render of the persistent Discord status board.
EOF
        ;;
    logs) cat <<'EOF'
c3r logs [TARGET_REPO] [AGENT_NAME]

Tails .c3r/RESEARCH_LOG.md for the named agent, or for all agents if no name
is given. Equivalent to attaching the tmux "logs" window but works without
tmux and can be piped/grep'd.

Ctrl-C to stop.
EOF
        ;;
    ask) cat <<'EOF'
c3r ask "QUESTION" [--choices opt1 opt2 ...] [--multi] [--thread ID]

Thin wrapper around bin/ask_human.py for testing or for sending yourself a
prompt from the CLI. Prints the reply on stdout (or TIMEOUT_NO_HUMAN_RESPONSE
after 15 min). Useful for:
  - smoke-testing the Discord bridge after editing the bot config
  - scripting: pipe the reply into another tool
EOF
        ;;
    ping) cat <<'EOF'
c3r ping [TARGET_REPO] AGENT_NAME MESSAGE...

Writes MESSAGE to the named agent's .c3r/INBOX.md (with a timestamp and
"you (cli)" author tag). The agent reads its INBOX at the start of every
iteration and acts on the contents.

Equivalent to replying in the agent's Discord thread. Use this from your
laptop; use the Discord thread on your phone.

Example:
  c3r ping policy "try the sigma curriculum from the Portela 2025 paper next"
EOF
        ;;
    add-agent|spawn) cat <<'EOF'
c3r spawn [TARGET_REPO] NAME ROLE "FOCUS" [--model MODEL] [--parent NAME]
c3r add-agent <same arguments>    (alias of spawn)

Dynamically add a new agent to a project (mid-run is fine):
  1. Checks the max_agents cap in state.json. If at the cap, fails with a clear
     message and exits non-zero so a caller (e.g. another agent) can react.
  2. Creates a new git worktree at <parent>/<repo>-<NAME> on branch agent/NAME.
  3. Seeds its .c3r/ dir from the chosen role template, substituting FOCUS.
  4. Creates a new standalone public thread in the Discord channel.
  5. Appends the agent to state.json (with optional parent field).
  6. If the project's tmux session is running, adds a new window to it
     running agent_loop.sh for the new agent — the agent is LIVE immediately.
  7. Updates the status board.

ROLE: generic | literature | coding | writing | custom
MODEL: claude-sonnet-4-6 (default) | claude-opus-4-6 | claude-haiku-4-5-20251001
PARENT: name of the spawning agent (optional, for tracking lineage in watch)

This command is intended to be called either by you from the CLI, or by an
agent from within its own iteration (via $C3R_BIN/c3r spawn ...) when it
decides a bounded sub-task warrants a dedicated worker.

Example:
  c3r spawn reader literature "read and summarize the Portela 2025 paper"
EOF
        ;;
    kill) cat <<'EOF'
c3r kill [TARGET_REPO] AGENT_NAME

Non-destructively stops an agent:
  1. Kills the agent's tmux window so the loop stops at its next iteration.
  2. Sets the agent's status to "stopped" in state.json.
  3. Posts a farewell message in the agent's Discord thread.
  4. Updates the status board.

Preserves:
  - The git worktree (<parent>/<repo>-<name>)
  - The branch (agent/<name>) and all commits
  - The Discord thread and its history
  - The agent's RESEARCH_LOG.md and INBOX_ARCHIVE.md

To restart a killed agent: re-add its tmux window manually, or `c3r reset`
followed by `c3r spawn` to get a fresh slate.

To fully delete an agent (destructive): see `c3r help reset`.

This command is intended to be called by the human when an agent's task is
done, or by an agent itself (`$C3R_BIN/c3r kill $C3R_AGENT_NAME`) when it
detects its spawned sub-task is complete.
EOF
        ;;
    reset) cat <<'EOF'
c3r reset [TARGET_REPO] AGENT_NAME

DESTRUCTIVE. Removes an agent completely:
  1. Confirms with y/N prompt.
  2. Removes the git worktree (<parent>/<repo>-<name>)
  3. Deletes the branch (agent/<name>)
  4. Removes the agent entry from state.json
  5. Archives the Discord thread (doesn't delete it — history is preserved)
  6. Redraws the status board

The agent's RESEARCH_LOG.md history survives in git reflog for a while; to
recover it, check `git reflog show agent/<name>`.
EOF
        ;;
    update) cat <<'EOF'
c3r update

Runs `git pull --ff-only` inside $C3R_DIR to fetch the latest c3r templates
and tools. Because targets symlink (not copy) c3r/bin into their scripts/
dir, tool updates propagate immediately. Template updates only affect newly
added agents — existing agents keep the PROMPT.md they were seeded with.
EOF
        ;;
    uninstall) cat <<'EOF'
c3r uninstall

Removes the ~/.local/bin/c3r symlink created by `c3r install`. Leaves:
  - the config file at ~/.config/c3r/config.env
  - the c3r repo itself at $C3R_DIR
  - all target-project state and worktrees

To fully remove, also delete the config dir manually:
  rm -rf ~/.config/c3r && rm -rf $C3R_DIR
EOF
        ;;
    doctor) cat <<'EOF'
c3r doctor [TARGET_REPO]

Runs environment and config checks:
  - DISCORD_BOT_TOKEN / CHANNEL_ID / USER_ID are set
  - tmux, flock, python3, git, claude CLI are all on PATH
  - claude CLI is logged in (claude --version)
  - Discord bot can post in the configured channel
  - Discord bot can create threads (permission check)
  - If a target is given: state.json is valid, worktrees exist

Exits 0 if everything is fine, non-zero otherwise.
EOF
        ;;
    config) cat <<'EOF'
c3r config

Shows the saved config file with secrets redacted. Config lives at:
  $CONFIG_FILE

To edit by hand: $EDITOR ~/.config/c3r/config.env
To wipe and re-enter: delete the file and re-run `c3r init`.
EOF
        ;;
    install) cat <<'EOF'
c3r install

Symlinks $C3R_DIR/c3r into ~/.local/bin/c3r so the command is on PATH.
Creates ~/.local/bin if missing. If ~/.local/bin is not on your PATH, prints
the line to add to your shell rc.

After install, `c3r` is available from any directory.
EOF
        ;;
    board) cat <<'EOF'
c3r board [TARGET_REPO] (bump|update)

Manage the persistent Discord status board message:
  update  re-render in place (cheap; normally done automatically by heartbeat)
  bump    delete and repost at the bottom of the channel — use when the board
          has scrolled away and you want it visible again

The bump command is also exposed as !c3r status in the Discord channel.
EOF
        ;;
    listen) cat <<'EOF'
c3r listen [TARGET_REPO]

Starts the Discord listener in the foreground. The listener does two things:
  1. Polls each agent's Discord thread for new replies and appends them to
     that agent's .c3r/INBOX.md (with ✓ reaction as ack).
  2. Polls the main channel for !c3r commands (pause, resume, status, ping,
     help) and executes them.

`c3r launch` auto-starts the listener in its own tmux window, so you
normally don't need to run this directly. Useful for debugging or running
the listener without the agent loops.
EOF
        ;;
    *) die "no help topic for '$topic' — try 'c3r help'" ;;
    esac
}

# ------------------------------------------------------------------
# install / uninstall / config
# ------------------------------------------------------------------
cmd_install() {
    local bin_dir="$HOME/.local/bin"
    mkdir -p "$bin_dir"
    local link="$bin_dir/c3r"
    [ -L "$link" ] || [ -f "$link" ] && { warn "$link exists; overwriting"; rm -f "$link"; }
    ln -s "$C3R_DIR/c3r" "$link"
    ok "symlinked $link → $C3R_DIR/c3r"
    case ":$PATH:" in
        *":$bin_dir:"*) ok "$bin_dir is on PATH" ;;
        *) warn "add to your shell rc: export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
    esac
}

cmd_uninstall() {
    local link="$HOME/.local/bin/c3r"
    if [ -L "$link" ]; then rm -f "$link"; ok "removed $link"
    else warn "$link not present"; fi
}

cmd_config() {
    if [ -f "$CONFIG_FILE" ]; then
        echo "$CONFIG_FILE:"
        sed 's/\(TOKEN="\)[^"]*"/\1***"/; s/\(USER_ID="\)[0-9]\{6,\}"/\1***"/' "$CONFIG_FILE"
    else
        warn "no config yet — run: c3r init"
    fi
}

# ------------------------------------------------------------------
# doctor
# ------------------------------------------------------------------
cmd_doctor() {
    load_config
    local fails=0
    info "environment"
    for v in DISCORD_BOT_TOKEN DISCORD_CHANNEL_ID DISCORD_USER_ID; do
        if [ -n "${!v:-}" ]; then ok "$v set"; else warn "$v not set"; fails=$((fails+1)); fi
    done
    info "tools"
    for tool in tmux flock python3 git claude jq; do
        if command -v "$tool" >/dev/null; then ok "$tool → $(command -v "$tool")"
        else warn "$tool missing"; [ "$tool" = jq ] || fails=$((fails+1)); fi
    done

    if [ -n "${DISCORD_BOT_TOKEN:-}" ] && [ -n "${DISCORD_CHANNEL_ID:-}" ]; then
        info "Discord bot reachability"
        if python3 - <<PY
import json, os, urllib.request
req = urllib.request.Request(
    f"https://discord.com/api/v10/channels/{os.environ['DISCORD_CHANNEL_ID']}",
    headers={"Authorization": f"Bot {os.environ['DISCORD_BOT_TOKEN']}"},
)
try:
    with urllib.request.urlopen(req, timeout=10) as r:
        ch = json.load(r)
    print(f"channel: #{ch.get('name','?')}  type={ch.get('type')}")
except Exception as e:
    print(f"ERROR: {e}"); raise SystemExit(1)
PY
        then ok "bot can read the channel"
        else warn "bot cannot read the channel — check token & invite perms"; fails=$((fails+1)); fi
    fi

    if [ "${1:-}" ]; then
        local target; target="$(resolve_target "$1")"
        if [ -f "$(state_path "$target")" ]; then
            ok "project state found at $(state_path "$target")"
        else
            warn "no project state at $target"
        fi
    fi

    [ "$fails" -eq 0 ] && ok "doctor: all checks passed" || { warn "doctor: $fails issue(s)"; return 1; }
}

