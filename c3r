cmd_launch() {
    load_config
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    local state; state="$(require_state "$target")"
    local session; session="c3r-$(python3 -c "import json;print(json.load(open('$state'))['project'])")"

    if tmux has-session -t "$session" 2>/dev/null; then
        ok "session '$session' already running — attach: tmux attach -t $session"
        return 0
    fi

    # Sync each agent's model from agent.conf → state.json so the dashboard
    # reflects runtime config. agent.conf is the source of truth at runtime.
    python3 - "$state" <<'PY'
import json, os, re, sys
path = sys.argv[1]
s = json.load(open(path))
changed = False
for a in s["agents"]:
    conf = os.path.join(a["worktree"], ".c3r/agent.conf")
    if not os.path.exists(conf): continue
    for line in open(conf):
        m = re.match(r'\s*AGENT_MODEL\s*=\s*"([^"]+)"', line)
        if m and a.get("model") != m.group(1):
            a["model"] = m.group(1); changed = True
if changed:
    json.dump(s, open(path, "w"), indent=2)
    print("[c3r] synced models from agent.conf → state.json")
PY

    "$C3R_DIR/scripts/launch_agents.sh" "$target"

    # Add a listener window
    tmux new-window -t "$session" -n "listen" \
        "bash -lc \"export C3R_STATE='$state' DISCORD_BOT_TOKEN='$DISCORD_BOT_TOKEN' DISCORD_CHANNEL_ID='$DISCORD_CHANNEL_ID' DISCORD_USER_ID='$DISCORD_USER_ID' && '$C3R_BIN/listen.py'\""
    ok "session '$session' up (including listener window)"
    info "attach: tmux attach -t $session"
}

cmd_watch() {
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    local state; state="$(require_state "$target")"
    local interval="${2:-1}"
    # Hide cursor, restore on exit
    printf '\e[?25l'
    trap 'printf "\e[?25h\n"; exit 0' INT TERM EXIT
    while :; do
        # Render a single screen to a buffer, then clear+print atomically
        local buf
        buf="$(C3R_STATE="$state" C3R_INTERVAL="$interval" python3 - <<'PY'
import json, os, time
from datetime import datetime, timezone
RESET, BOLD, DIM = "\033[0m", "\033[1m", "\033[2m"
GREEN, YELLOW, RED, BLUE, CYAN, GREY = "\033[32m","\033[33m","\033[31m","\033[34m","\033[36m","\033[90m"
ICON = {"idle":"○","running":f"{GREEN}●{RESET}","paused":f"{YELLOW}⏸{RESET}","error":f"{RED}✗{RESET}","stopped":f"{GREY}·{RESET}"}

s = json.load(open(os.environ["C3R_STATE"]))
try:
    cols = int(os.environ.get("COLUMNS") or os.get_terminal_size().columns)
except OSError:
    cols = 100
bar = "─" * min(cols, 100)
paused = " " + (YELLOW + "[PAUSED]" + RESET if s.get("paused") else GREEN + "[running]" + RESET)
print(f"{BOLD}c3r · {s['project']}{RESET}{paused}   {DIM}gpu_lock={s.get('gpu_lock','?')}  refresh={os.environ['C3R_INTERVAL']}s  q=quit{RESET}")
print(bar)
cap = s.get("max_agents", "?")
total = len(s["agents"])
print(f"{BOLD}agents:{RESET} {total}/{cap}")
hdr = f"{BOLD}{'':2}{'AGENT':<18}{'STATUS':<9}{'MODEL':<10}{'ITER':<7}{'CTX%':>5}  {'LAST':<12}{'FAIL':>5}{RESET}"
print(hdr)

# Build parent→children index and render as a tree (DFS)
by_name = {a["name"]: a for a in s["agents"]}
children = {}
for a in s["agents"]:
    children.setdefault(a.get("parent"), []).append(a["name"])
def render(agent_name, depth):
    a = by_name[agent_name]
    st = a.get("status","idle")
    icon = ICON.get(st, "·")
    model = a.get("model","").replace("claude-","").replace("-4-6","").replace("-4-5-20251001","")[:10]
    iter_n = f"#{a.get('last_iter',0)}"
    ctx = a.get("last_context_pct",0)
    ctx_col = GREEN if ctx<50 else YELLOW if ctx<75 else RED
    ts = a.get("last_iter_ts")
    rel = "—"
    if ts:
        try:
            dt = datetime.fromisoformat(ts)
            secs = int((datetime.now(timezone.utc)-dt).total_seconds())
            rel = f"{secs}s ago" if secs<60 else f"{secs//60}m ago" if secs<3600 else f"{secs//3600}h ago"
        except Exception: pass
    fail = a.get("fail_streak",0)
    fail_col = RED if fail>=3 else YELLOW if fail>0 else ""
    indent = ("  " + "  " * depth) + ("└─ " if depth > 0 else "")
    name_field = f"{indent}{a['name']}"[:18]
    print(f"{icon} {name_field:<18} {st:<9}{model:<10}{iter_n:<7}{ctx_col}{ctx:>4}%{RESET}  {rel:<12}{fail_col}{fail:>5}{RESET}")
    for child in children.get(a["name"], []):
        render(child, depth + 1)
for root in children.get(None, []):
    render(root, 0)
print(bar)

# ---- INBOX panel: latest 3 messages across all agents, with responses ----
import re
ENTRY_RE = re.compile(
    r'---\s*\n'
    r'\[([^\]]+)\]\s*([^\n→]+?)\s*→\s*(\w+)\s*\n'
    r'MSG:\s*(.+?)(?=\n(?:RESP:|---|\Z))'
    r'(?:\nRESP:\s*(.+?))?(?=\n---|\Z)',
    re.DOTALL,
)
def parse_msgs(path, has_response):
    if not os.path.exists(path): return []
    out = []
    for m in ENTRY_RE.finditer(open(path).read()):
        ts, author, agent, msg, resp = m.groups()
        out.append({
            "ts": ts.strip(),
            "author": author.strip(),
            "agent": agent.strip(),
            "msg": " ".join(msg.strip().splitlines()),
            "resp": (resp or "").strip() if has_response else "",
            "unread": not has_response,
        })
    return out

all_msgs = []
for a in s["agents"]:
    all_msgs += parse_msgs(os.path.join(a["worktree"], ".c3r/INBOX.md"), False)
    all_msgs += parse_msgs(os.path.join(a["worktree"], ".c3r/INBOX_ARCHIVE.md"), True)
all_msgs.sort(key=lambda m: m["ts"], reverse=True)

print(f"{BOLD}INBOX{RESET}  {DIM}(last 3 · 📬 unread · ✉ read+responded){RESET}")
if not all_msgs:
    print(f"  {DIM}(no messages — send via: c3r ping <agent> <msg>  or reply in a thread){RESET}")
else:
    for m in all_msgs[:3]:
        icon, col, lbl = ("📬", YELLOW, "UNREAD") if m["unread"] else ("✉", GREEN, "read  ")
        tag = f"→{m['agent']}"
        print(f"  {col}{icon} {lbl}{RESET} {BOLD}{tag:<10}{RESET} {DIM}{m['ts']}  from {m['author']}{RESET}")
        print(f"      {BOLD}msg:{RESET}  {m['msg'][:cols-12]}")
        if m["resp"]:
            print(f"      {CYAN}resp:{RESET} {m['resp'][:cols-12]}")
print(bar)

# Last 2 log lines per agent
for a in s["agents"]:
    log = os.path.join(a["worktree"], ".c3r/RESEARCH_LOG.md")
    if os.path.exists(log):
        lines = [l for l in open(log).read().strip().splitlines() if l.strip()]
        last = lines[-2:] if len(lines) >= 2 else lines
        if last:
            print(f"{CYAN}{a['name']}:{RESET}")
            for ln in last:
                print(f"  {DIM}{ln[:cols-4]}{RESET}")
print(f"{DIM}{datetime.now().strftime('%H:%M:%S')}  ^C to exit{RESET}")
PY
)"
        clear
        printf '%s' "$buf"
        # Wait for interval or 'q' keypress
        read -rsn1 -t "$interval" key 2>/dev/null || true
        [ "${key:-}" = "q" ] && break
    done
    printf '\e[?25h\n'
}

