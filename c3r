cmd_spawn() {
    load_config
    local target; target="$(resolve_target "${1:-}")"
    if [ -f "$target/.c3r/state.json" ]; then shift; else target="$PWD"; fi
    local state; state="$(require_state "$target")"

    local name="${1:?usage: c3r spawn NAME ROLE \"FOCUS\" [--model M] [--max-iters N]}"; shift
    local role="${1:?role required}"; shift
    local focus="${1:?focus required}"; shift
    local model="claude-sonnet-4-6"
    local parent_override=""
    local max_iters=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --model) model="$2"; shift 2 ;;
            --parent) parent_override="$2"; shift 2 ;;
            --max-iters) max_iters="$2"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    # Default sub-agents to a 20-iter budget so they self-kill if their parent
    # forgets them. Top-level (CLI-spawned with no parent) defaults to unlimited.
    if [ -z "$max_iters" ]; then
        if [ -n "${C3R_AGENT_NAME:-}" ] || [ -n "$parent_override" ]; then
            max_iters=20
        else
            max_iters=0  # 0 = unlimited
        fi
    fi
    [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid name: letters/digits/dash/underscore only"

    # Determine parent: explicit flag > env (auto when called from an agent) > none
    local parent="$parent_override"
    [ -z "$parent" ] && parent="${C3R_AGENT_NAME:-}"

    # Enforce max_agents cap (only count ACTIVE agents — stopped ones don't take a slot)
    python3 - "$state" "$name" "$parent" <<'PY'
