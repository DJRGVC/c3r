#!/usr/bin/env bash
# c3r — Continuous Context Claude Research CLI
#
# Subcommands:
#   c3r init [target-repo]   Interactive wizard: Discord setup, smoke test,
#                            worktree creation, .ralph/ seeding.
#   c3r launch [target-repo] Launch the tmux session with both agents.
#   c3r stop [session]       Kill the tmux session.
#   c3r doctor               Check env, config, ralph install, Discord reachability.
#   c3r config               Show the saved config file path and contents.
#   c3r install              Symlink `c3r` into ~/.local/bin so it's on PATH.
#   c3r help                 This message.
#
# Config is persisted to ~/.config/c3r/config.env and auto-sourced on every run.
set -euo pipefail

# --- paths ---
C3R_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/c3r"
CONFIG_FILE="$CONFIG_DIR/config.env"

# --- colors ---
if [ -t 1 ]; then
    BOLD=$'\e[1m'; DIM=$'\e[2m'; GREEN=$'\e[32m'; YELLOW=$'\e[33m'; RED=$'\e[31m'; RESET=$'\e[0m'
else
    BOLD=""; DIM=""; GREEN=""; YELLOW=""; RED=""; RESET=""
fi

info()  { echo "${BOLD}[c3r]${RESET} $*"; }
ok()    { echo "${GREEN}[c3r] ✓${RESET} $*"; }
warn()  { echo "${YELLOW}[c3r] ⚠${RESET} $*" >&2; }
die()   { echo "${RED}[c3r] ✗${RESET} $*" >&2; exit 1; }
ask()   { local prompt="$1" default="${2:-}" var; read -rp "$prompt" var; echo "${var:-$default}"; }

# --- config persistence ---
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck disable=SC1090
        set -a; . "$CONFIG_FILE"; set +a
    fi
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
# c3r config — auto-sourced by the c3r CLI.
# chmod 600; contains secrets.
export DISCORD_BOT_TOKEN="${DISCORD_BOT_TOKEN:-}"
export DISCORD_CHANNEL_ID="${DISCORD_CHANNEL_ID:-}"
export DISCORD_USER_ID="${DISCORD_USER_ID:-}"
EOF
    chmod 600 "$CONFIG_FILE"
    ok "saved config → $CONFIG_FILE"
}

# --- subcommand: install ---
cmd_install() {
    local bin_dir="$HOME/.local/bin"
    mkdir -p "$bin_dir"
    local link="$bin_dir/c3r"
    if [ -L "$link" ] || [ -f "$link" ]; then
        warn "$link already exists; overwriting"
        rm -f "$link"
    fi
    ln -s "$C3R_DIR/c3r" "$link"
    ok "symlinked $link → $C3R_DIR/c3r"
    case ":$PATH:" in
        *":$bin_dir:"*) ok "$bin_dir is already on PATH" ;;
        *) warn "add this to your shell rc:  export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
    esac
}

# --- subcommand: config ---
cmd_config() {
    if [ -f "$CONFIG_FILE" ]; then
        echo "$CONFIG_FILE:"
        sed 's/\(TOKEN="\)[^"]*"/\1***"/; s/\(ID="\)[0-9]\{6,\}/\1***/' "$CONFIG_FILE"
    else
        warn "no config file yet; run: c3r init"
    fi
}

# --- subcommand: doctor ---
cmd_doctor() {
    local fails=0
    load_config

    info "checking environment..."
    for v in DISCORD_BOT_TOKEN DISCORD_CHANNEL_ID DISCORD_USER_ID; do
        if [ -n "${!v:-}" ]; then ok "$v set"; else warn "$v not set"; fails=$((fails+1)); fi
    done

    command -v tmux   >/dev/null && ok "tmux found"   || { warn "tmux missing";   fails=$((fails+1)); }
    command -v flock  >/dev/null && ok "flock found"  || { warn "flock missing";  fails=$((fails+1)); }
    command -v python3 >/dev/null && ok "python3 found" || { warn "python3 missing"; fails=$((fails+1)); }
    command -v ralph  >/dev/null && ok "ralph found ($(command -v ralph))" \
        || warn "ralph-claude-code not on PATH — install it before launching"

    if [ "$fails" -eq 0 ]; then
        ok "doctor: all checks passed"
    else
        warn "doctor: $fails issue(s) — fix before running 'c3r init' or 'c3r launch'"
        return 1
    fi
}

# --- interactive Discord wizard ---
wizard_discord() {
    info "Discord bot setup"
    cat <<'EOF'

Steps (roughly 5 minutes):
  1. https://discord.com/developers/applications → New Application
  2. Sidebar → Bot → Add Bot → copy the bot token
  3. Sidebar → OAuth2 → URL Generator → scopes: bot
     permissions: Send Messages, Read Message History, Add Reactions, View Channels
  4. Open the generated URL → invite the bot to a server you control
  5. In Discord: Settings → Advanced → enable Developer Mode
  6. Right-click the target channel → Copy Channel ID
  7. Right-click your own username → Copy User ID

EOF
    load_config
    local tok cid uid
    tok=$(ask "Discord bot token [${DISCORD_BOT_TOKEN:+keep existing}]: " "${DISCORD_BOT_TOKEN:-}")
    cid=$(ask "Discord channel ID [${DISCORD_CHANNEL_ID:-}]: " "${DISCORD_CHANNEL_ID:-}")
    uid=$(ask "Your Discord user ID [${DISCORD_USER_ID:-}]: " "${DISCORD_USER_ID:-}")

    [ -n "$tok" ] || die "bot token is required"
    [ -n "$cid" ] || die "channel ID is required"
    [ -n "$uid" ] || die "user ID is required"

    export DISCORD_BOT_TOKEN="$tok"
    export DISCORD_CHANNEL_ID="$cid"
    export DISCORD_USER_ID="$uid"
    save_config
}

# --- smoke test ---
wizard_smoke() {
    info "running Discord round-trip smoke test..."
    echo "${DIM}(free-text mode — reply to the bot in Discord)${RESET}"
    local reply
    if ! reply=$("$C3R_DIR/bin/ask_human.py" "c3r smoke test — reply with any text" --timeout-min 5); then
        die "smoke test failed — check bot token and channel ID"
    fi
    if [ "$reply" = "TIMEOUT_NO_HUMAN_RESPONSE" ]; then
        warn "timed out waiting for your reply — is the bot in the right channel?"
        local again
        again=$(ask "Retry smoke test? [y/N]: " "N")
        [[ "$again" =~ ^[Yy] ]] && wizard_smoke && return 0
        die "smoke test abandoned"
    fi
    ok "free-text reply received: ${reply}"

    echo
    info "testing MCQ reaction mode..."
    local choice
    if ! choice=$("$C3R_DIR/bin/ask_human.py" "MCQ smoke test — tap one" \
        --choices "left" "middle" "right" --timeout-min 5); then
        die "MCQ smoke test failed"
    fi
    [ "$choice" = "TIMEOUT_NO_HUMAN_RESPONSE" ] && die "MCQ test timed out"
    ok "MCQ reply received: ${choice}"
}

# --- wire c3r into target repo ---
wizard_wire() {
    local target="$1" a="$2" b="$3"
    info "creating worktrees in $target ..."
    "$C3R_DIR/scripts/setup_worktrees.sh" "$target" "$a" "$b"

    local parent repo_name
    parent="$(dirname "$target")"
    repo_name="$(basename "$target")"

    seed_worktree() {
        local wt="$1" role="$2"
        local ralph="$wt/.ralph"
        mkdir -p "$ralph"
        [ -f "$ralph/PROMPT.md" ]       || cp "$C3R_DIR/templates/PROMPT_${role}.md" "$ralph/PROMPT.md"
        [ -f "$ralph/fix_plan.md" ]     || cp "$C3R_DIR/templates/fix_plan.md"       "$ralph/fix_plan.md"
        [ -f "$ralph/RESEARCH_LOG.md" ] || cp "$C3R_DIR/templates/RESEARCH_LOG.md"   "$ralph/RESEARCH_LOG.md"
        [ -f "$ralph/.ralphrc" ]        || cp "$C3R_DIR/templates/ralphrc.example"   "$ralph/.ralphrc"
        ok "seeded $ralph/ ($role)"
    }

    seed_worktree "$parent/${repo_name}-${a}" "$a"
    seed_worktree "$parent/${repo_name}-${b}" "$b"

    local link="$target/scripts/c3r"
    mkdir -p "$target/scripts"
    if [ ! -e "$link" ]; then
        ln -s "$C3R_DIR/bin" "$link"
        ok "symlinked $link → $C3R_DIR/bin"
    fi
}

# --- subcommand: init ---
cmd_init() {
    local target="${1:-$PWD}"
    target="$(cd "$target" && pwd)"
    [ -d "$target/.git" ] || die "not a git repo: $target"

    local a b
    a=$(ask "agent A name [policy]: " "policy")
    b=$(ask "agent B name [perception]: " "perception")

    info "target:  $target"
    info "agents:  $a, $b"
    echo

    # Discord config: reuse or re-wizard
    load_config
    if [ -n "${DISCORD_BOT_TOKEN:-}" ] && [ -n "${DISCORD_CHANNEL_ID:-}" ] && [ -n "${DISCORD_USER_ID:-}" ]; then
        ok "Discord config already saved ($CONFIG_FILE)"
        local reuse
        reuse=$(ask "Reuse existing config? [Y/n]: " "Y")
        [[ "$reuse" =~ ^[Nn] ]] && wizard_discord
    else
        wizard_discord
    fi

    local do_smoke
    do_smoke=$(ask "Run Discord smoke test? [Y/n]: " "Y")
    [[ ! "$do_smoke" =~ ^[Nn] ]] && wizard_smoke

    wizard_wire "$target" "$a" "$b"

    cat <<EOF

${GREEN}${BOLD}c3r init complete.${RESET}

Next steps:
  1. Inside each worktree, once:
       cd $(dirname "$target")/$(basename "$target")-${a} && ralph-enable-ci
       cd $(dirname "$target")/$(basename "$target")-${b} && ralph-enable-ci
  2. Edit each worktree's .ralph/fix_plan.md with 3-5 concrete starting tasks.
  3. Launch:
       c3r launch $target $a $b
EOF
}

# --- subcommand: launch ---
cmd_launch() {
    load_config
    local target="${1:-$PWD}"
    target="$(cd "$target" && pwd)"
    local a="${2:-policy}" b="${3:-perception}"
    exec "$C3R_DIR/scripts/launch_agents.sh" "$target" "$a" "$b"
}

# --- subcommand: stop ---
cmd_stop() {
    local session="${1:-${C3R_TMUX_SESSION:-c3r}}"
    if tmux has-session -t "$session" 2>/dev/null; then
        tmux kill-session -t "$session"
        ok "killed session: $session"
    else
        warn "no tmux session named '$session'"
    fi
}

# --- help ---
cmd_help() {
    sed -n '3,14p' "$0" | sed 's/^# \{0,1\}//'
}

# --- dispatch ---
load_config
case "${1:-help}" in
    init)    shift; cmd_init    "$@" ;;
    launch)  shift; cmd_launch  "$@" ;;
    stop)    shift; cmd_stop    "$@" ;;
    doctor)  shift; cmd_doctor  "$@" ;;
    config)  shift; cmd_config  "$@" ;;
    install) shift; cmd_install "$@" ;;
    help|-h|--help) cmd_help ;;
    *) cmd_help; die "unknown subcommand: $1" ;;
esac
