#!/usr/bin/env bash
# c3r — Continuous Context Claude Research CLI
# See `c3r help` for an overview or `c3r help <command>` for details.
set -euo pipefail

C3R_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
C3R_BIN="$C3R_DIR/bin"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/c3r"
CONFIG_FILE="$CONFIG_DIR/config.env"
C3R_VERSION="$(cat "$C3R_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo unknown)"
C3R_GIT_HEAD="$(git -C "$C3R_DIR" rev-parse --short HEAD 2>/dev/null || echo ?)"

if [ -t 1 ]; then
    BOLD=$'\e[1m'; DIM=$'\e[2m'; GREEN=$'\e[32m'; YELLOW=$'\e[33m'; RED=$'\e[31m'; BLUE=$'\e[34m'; RESET=$'\e[0m'
else
    BOLD=""; DIM=""; GREEN=""; YELLOW=""; RED=""; BLUE=""; RESET=""
fi

info()  { echo "${BOLD}[c3r]${RESET} $*"; }
ok()    { echo "${GREEN}[c3r] ✓${RESET} $*"; }
warn()  { echo "${YELLOW}[c3r] ⚠${RESET} $*" >&2; }
die()   { echo "${RED}[c3r] ✗${RESET} $*" >&2; exit 1; }
ask()   { local prompt="$1" default="${2:-}" var; read -rp "$prompt" var; echo "${var:-$default}"; }
# Silent input for secrets — no echo to terminal, no shell history
ask_secret() { local prompt="$1" default="${2:-}" var; read -rsp "$prompt" var; echo >&2; echo "${var:-$default}"; }

load_config() {
    [ -f "$CONFIG_FILE" ] && { set -a; . "$CONFIG_FILE"; set +a; } || true
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<EOF
# c3r config — auto-sourced by the c3r CLI. chmod 600; contains secrets.
export DISCORD_BOT_TOKEN="${DISCORD_BOT_TOKEN:-}"
export DISCORD_CHANNEL_ID="${DISCORD_CHANNEL_ID:-}"
export DISCORD_USER_ID="${DISCORD_USER_ID:-}"
# Plan tier for usage % calculation in watch. One of:
#   pro       — \$20/mo, ~\$30/wk effective Sonnet equivalent
#   max-5x    — \$100/mo, ~\$150/wk effective
#   max-20x   — \$200/mo, ~\$600/wk effective
#   api       — pay-as-you-go (no weekly cap)
#   unknown   — show absolute spend without budget %
export C3R_PLAN="${C3R_PLAN:-unknown}"
EOF
    chmod 600 "$CONFIG_FILE"
    ok "saved config → $CONFIG_FILE"
}

# Resolve target project path:
#   1. Explicit arg wins
#   2. $C3R_STATE env var (set by agent_loop.sh when called from inside an agent)
#   3. $PWD if it has .c3r/state.json
#   4. git toplevel of $PWD
resolve_target() {
    local arg="${1:-}"
    if [ -n "$arg" ]; then cd "$arg" && pwd; return; fi
    if [ -n "${C3R_STATE:-}" ] && [ -f "$C3R_STATE" ]; then
        dirname "$(dirname "$C3R_STATE")"
        return
    fi
    if [ -f "$PWD/.c3r/state.json" ]; then echo "$PWD"; return; fi
    git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || echo "$PWD"
}

state_path() { echo "$1/.c3r/state.json"; }

require_state() {
    local arg="${1:-}"
    # Prefer $C3R_STATE when set (agent calling c3r from inside a worktree)
    if [ -n "${C3R_STATE:-}" ] && [ -f "$C3R_STATE" ]; then
        echo "$C3R_STATE"
        return
    fi
    local s; s="$(state_path "$arg")"
    [ -f "$s" ] || die "no project state at $s — run 'c3r init' in that repo first, or set \$C3R_STATE"
    echo "$s"
}

# Small Python helper for JSON state mutations. Usage: py_state <script>
py_state() {
    python3 - "$@"
}

