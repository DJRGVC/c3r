cmd_add_agent() { cmd_spawn "$@"; }

cmd_kill() {
    load_config
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    if [ -f "$target/.c3r/state.json" ]; then shift; else target="$PWD"; fi
    local state; state="$(require_state "$target")"
    local name="${1:?usage: c3r kill AGENT_NAME}"

    # Compute the set of agents to kill: target + all descendants
    # Enforce permission: if called from an agent (C3R_AGENT_NAME set), the
    # target must be self or a descendant of self.
    local caller="${C3R_AGENT_NAME:-}"
    local to_kill; to_kill=$(python3 - "$state" "$name" "$caller" <<'PY'
import json, sys
sp, target, caller = sys.argv[1:]
s = json.load(open(sp))
by_name = {a["name"]: a for a in s["agents"]}
if target not in by_name:
    print(f"ERR: no such agent: {target}", file=sys.stderr); sys.exit(2)
# Compute descendants
def descendants(n):
    out = [n]
    for a in s["agents"]:
        if a.get("parent") == n:
            out += descendants(a["name"])
    return out
kill_set = descendants(target)
# Permission check for agent callers
if caller:
    # caller may only kill self or a descendant of self
    caller_desc = set(descendants(caller))
    if target not in caller_desc and target != caller:
        print(f"ERR: agent '{caller}' cannot kill '{target}' (not in its subtree)", file=sys.stderr); sys.exit(3)
print(" ".join(kill_set))
PY
)
    local rc=$?; [ "$rc" -ne 0 ] && return $rc
    [ -z "$to_kill" ] && die "nothing to kill"

    local session; session="c3r-$(python3 -c "import json;print(json.load(open('$state'))['project'])")"
    for agent in $to_kill; do
        # Kill tmux window if session exists
        if tmux has-session -t "$session" 2>/dev/null; then
            tmux kill-window -t "$session:$agent" 2>/dev/null || true
        fi
        # Farewell in thread + mark stopped in state.json
        python3 - "$state" "$agent" <<'PY'
import json, os, sys, subprocess
sp, name = sys.argv[1:]
s = json.load(open(sp))
agent = next((a for a in s["agents"] if a["name"] == name), None)
if not agent: sys.exit(0)
agent["status"] = "stopped"
json.dump(s, open(sp, "w"), indent=2)
# Farewell post
if agent.get("thread_id"):
    subprocess.run([f"{os.path.dirname(os.path.realpath(__file__))}/bin/notify.py",
                    "--thread", agent["thread_id"],
                    "🛑 Agent stopped. Worktree and history preserved."],
                   check=False, cwd=os.path.dirname(os.path.realpath(__file__)))
PY
        ok "killed $agent"
    done
    "$C3R_BIN/status_board.py" update --state "$state" || true
}

cmd_reset() {
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    if [ -f "$target/.c3r/state.json" ]; then shift; else target="$PWD"; fi
    local name="${1:?usage: c3r reset [path] AGENT_NAME}"
    local state; state="$(require_state "$target")"
    local wt; wt="$(python3 -c "import json;s=json.load(open('$state'));print(next(a['worktree'] for a in s['agents'] if a['name']=='$name'))")"
    warn "this will delete: $wt and branch agent/$name"
    local confirm; confirm=$(ask "Proceed? [y/N]: " "N")
    [[ "$confirm" =~ ^[Yy] ]] || { info "aborted"; return 0; }
    cd "$target"
    git worktree remove --force "$wt" || true
    git branch -D "agent/$name" || true
    python3 - "$state" "$name" <<'PY'
import json, sys
state_path, name = sys.argv[1:3]
s = json.load(open(state_path))
s["agents"] = [a for a in s["agents"] if a["name"] != name]
json.dump(s, open(state_path, "w"), indent=2)
PY
    "$C3R_BIN/status_board.py" update --state "$state" || true
    ok "removed agent $name"
}

cmd_board() {
    load_config
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    if [ -f "$target/.c3r/state.json" ]; then shift; else target="$PWD"; fi
    local state; state="$(require_state "$target")"
    local sub="${1:?usage: c3r board (bump|update)}"
    "$C3R_BIN/status_board.py" "$sub" --state "$state"
}

cmd_update() {
    info "git pull in $C3R_DIR"
    git -C "$C3R_DIR" pull --ff-only
}

cmd_listen() {
    load_config
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    local state; state="$(require_state "$target")"
    export C3R_STATE="$state"
    exec "$C3R_BIN/listen.py"
}

# ------------------------------------------------------------------
# dispatch
# ------------------------------------------------------------------
load_config
cmd="${1:-help}"; shift || true
case "$cmd" in
    init)      cmd_init      "$@" ;;
    launch)    cmd_launch    "$@" ;;
    attach|a)  cmd_attach    "$@" ;;
    watch|w)   cmd_watch     "$@" ;;
    stop)      cmd_stop      "$@" ;;
    pause)     cmd_pause     "$@" ;;
    resume)    cmd_resume    "$@" ;;
    status)    cmd_status    "$@" ;;
    logs)      cmd_logs      "$@" ;;
    ask)       cmd_ask       "$@" ;;
    ping)      cmd_ping      "$@" ;;
    add-agent) cmd_add_agent "$@" ;;
    spawn)     cmd_spawn     "$@" ;;
    kill)      cmd_kill      "$@" ;;
    reset)     cmd_reset     "$@" ;;
    update)    cmd_update    "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    doctor)    cmd_doctor    "$@" ;;
    config)    cmd_config    "$@" ;;
    install)   cmd_install   "$@" ;;
    board)     cmd_board     "$@" ;;
    listen)    cmd_listen    "$@" ;;
    help|-h|--help) cmd_help "$@" ;;
    *) cmd_help; die "unknown command: $cmd" ;;
esac
