cmd_spawn() {
    load_config
    local target; target="$(cd "${1:-$PWD}" && pwd)"
    if [ -f "$target/.c3r/state.json" ]; then shift; else target="$PWD"; fi
    local state; state="$(require_state "$target")"

    local name="${1:?usage: c3r spawn NAME ROLE \"FOCUS\" [--model M]}"; shift
    local role="${1:?role required}"; shift
    local focus="${1:?focus required}"; shift
    local model="claude-sonnet-4-6"
    local parent_override=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --model) model="$2"; shift 2 ;;
            --parent) parent_override="$2"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done
    [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid name: letters/digits/dash/underscore only"

    # Determine parent: explicit flag > env (auto when called from an agent) > none
    local parent="$parent_override"
    [ -z "$parent" ] && parent="${C3R_AGENT_NAME:-}"

    # Enforce max_agents cap
    python3 - "$state" "$name" "$parent" <<'PY'
import json, sys
sp, name, parent = sys.argv[1], sys.argv[2], sys.argv[3]
s = json.load(open(sp))
if any(a["name"] == name for a in s["agents"]):
    print(f"[spawn] agent '{name}' already exists", file=sys.stderr); sys.exit(2)
cap = s.get("max_agents", 4)
if len(s["agents"]) >= cap:
    print(f"[spawn] max_agents cap reached ({cap}) — kill an agent first", file=sys.stderr); sys.exit(3)
if parent and not any(a["name"] == parent for a in s["agents"]):
    print(f"[spawn] parent '{parent}' does not exist", file=sys.stderr); sys.exit(4)
PY
    local rc=$?
    [ "$rc" -ne 0 ] && return $rc

    # Create worktree
    local parent_dir; parent_dir="$(dirname "$target")"
    local repo_name; repo_name="$(basename "$target")"
    local wt="$parent_dir/${repo_name}-${name}"
    local branch="agent/$name"
    ( cd "$target" && {
        git show-ref --verify --quiet "refs/heads/$branch" || git branch "$branch" HEAD
        git worktree add "$wt" "$branch" 2>/dev/null || git worktree add --force "$wt" "$branch"
    } ) || die "worktree creation failed"

    # Seed .c3r/
    mkdir -p "$wt/.c3r"
    local tpl="$C3R_DIR/templates/PROMPT_${role}.md"
    [ -f "$tpl" ] || tpl="$C3R_DIR/templates/PROMPT_generic.md"
    local siblings="(see state.json)"
    render_prompt "$tpl" "$wt/.c3r/PROMPT.md" "$name" "$role" "$focus" "$siblings" "(agent-defined)" "(sibling-owned)" "1"
    cp "$C3R_DIR/templates/fix_plan.md"     "$wt/.c3r/fix_plan.md"
    cp "$C3R_DIR/templates/RESEARCH_LOG.md" "$wt/.c3r/RESEARCH_LOG.md"
    cp "$C3R_DIR/templates/INBOX.md"        "$wt/.c3r/INBOX.md"
    printf '# INBOX ARCHIVE\n' > "$wt/.c3r/INBOX_ARCHIVE.md"
    write_agent_conf "$wt" "$name" "$role" "$model"

    # Create Discord thread
    python3 - "$state" "$name" "$role" "$model" "$focus" "$wt" "$parent" <<'PY'
import json, os, sys, urllib.request
sp, name, role, model, focus, wt, parent = sys.argv[1:]
parent = parent or None
s = json.load(open(sp))
token = os.environ["DISCORD_BOT_TOKEN"]; channel = s["channel_id"]
# Create standalone public thread
